# ─── Chronos Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore.

# ── Supabase (cross-device sync) ──────────────────────────────────────────────
# Get these from: supabase.com → Your Project → Settings → API
# Leave blank to run fully offline (all data stays in localStorage).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Google Calendar sync ──────────────────────────────────────────────────────
# 1. Go to: console.cloud.google.com
# 2. Create a project, enable "Google Calendar API"
# 3. Create an OAuth 2.0 Client ID (Web application type)
# 4. Add authorized redirect URI: https://yourdomain.com/oauth/google
# 5. Paste the client ID below (the client secret is NOT needed for PKCE)
VITE_GOOGLE_CLIENT_ID=

# ── Web Push (background notifications) ──────────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
# Then add a push endpoint to your Supabase Edge Functions or backend.
VITE_VAPID_PUBLIC_KEY=
